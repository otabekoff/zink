fn is_prime(n) {
  if n < 2 { return false }
  if n == 2 { return true }
  if n % 2 == 0 { return false }
  let i = 3
  while i * i <= n {
    if n % i == 0 { return false }
    i = i + 2
  }
  return true
}

say "=== Prime Numbers up to 100 ==="
let primes = []
let n = 2
while n <= 100 {
  if is_prime(n) {
    push(primes, n)
  }
  n = n + 1
}

say "Found {len(primes)} primes:"
say join(primes, ", ")
