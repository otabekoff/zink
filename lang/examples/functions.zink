fn greet(name) {
  return "Hello, {name}! Welcome to Zink."
}

fn add(a, b) {
  return a + b
}

fn factorial(n) {
  if n <= 1 {
    return 1
  }
  return n * factorial(n - 1)
}

say greet("Alice")
say greet("Bob")
say ""
say "3 + 4 = {add(3, 4)}"
say ""
say "=== Factorials ==="
let i = 1
while i <= 8 {
  say "{i}! = {factorial(i)}"
  i = i + 1
}
