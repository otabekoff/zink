{
  "name": "zink",
  "scopeName": "source.zink",
  "fileTypes": ["zink"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#constants" },
    { "include": "#builtins" },
    { "include": "#functions" },
    { "include": "#operators" },
    { "include": "#identifiers" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.zink",
          "match": "#.*$"
        },
        {
          "name": "comment.line.double-slash.zink",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.zink",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.zink",
              "match": "\\\\[nrt\\\\\"']"
            },
            {
              "name": "meta.interpolation.zink",
              "begin": "\\{",
              "end": "\\}",
              "beginCaptures": {
                "0": { "name": "punctuation.section.interpolation.begin.zink" }
              },
              "endCaptures": {
                "0": { "name": "punctuation.section.interpolation.end.zink" }
              },
              "patterns": [
                { "include": "source.zink" }
              ]
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.zink",
          "match": "\\b\\d+\\.\\d+\\b"
        },
        {
          "name": "constant.numeric.integer.zink",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.zink",
          "match": "\\b(if|else|while|loop|times|return)\\b"
        },
        {
          "name": "keyword.declaration.zink",
          "match": "\\b(let|fn)\\b"
        },
        {
          "name": "keyword.other.zink",
          "match": "\\b(say)\\b"
        },
        {
          "name": "keyword.operator.logical.zink",
          "match": "\\b(and|or|not)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.zink",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.null.zink",
          "match": "\\bnull\\b"
        }
      ]
    },
    "builtins": {
      "patterns": [
        {
          "name": "support.function.zink",
          "match": "\\b(len|push|pop|str|num|floor|ceil|round|abs|sqrt|pow|max|min|random|range|type|contains|join|split|upper|lower|trim|slice|reverse|sort|map|filter|reduce)\\b(?=\\s*\\()"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "match": "\\b(fn)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
          "captures": {
            "1": { "name": "keyword.declaration.zink" },
            "2": { "name": "entity.name.function.zink" }
          }
        },
        {
          "name": "entity.name.function.call.zink",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.zink",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.arithmetic.zink",
          "match": "[+\\-*/%]"
        },
        {
          "name": "keyword.operator.assignment.zink",
          "match": "="
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.zink",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.bracket.round.zink",
          "match": "[()]"
        },
        {
          "name": "punctuation.bracket.curly.zink",
          "match": "[{}]"
        },
        {
          "name": "punctuation.bracket.square.zink",
          "match": "[\\[\\]]"
        },
        {
          "name": "punctuation.separator.comma.zink",
          "match": ","
        },
        {
          "name": "punctuation.accessor.dot.zink",
          "match": "\\."
        }
      ]
    }
  }
}
