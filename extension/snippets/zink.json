{
  "Function": {
    "prefix": "fn",
    "body": [
      "fn ${1:name}(${2:params}) {",
      "  ${0}",
      "}"
    ],
    "description": "Define a function"
  },
  "If": {
    "prefix": "if",
    "body": [
      "if ${1:condition} {",
      "  ${0}",
      "}"
    ],
    "description": "If statement"
  },
  "If-Else": {
    "prefix": "ife",
    "body": [
      "if ${1:condition} {",
      "  ${2}",
      "} else {",
      "  ${0}",
      "}"
    ],
    "description": "If-else statement"
  },
  "While Loop": {
    "prefix": "while",
    "body": [
      "while ${1:condition} {",
      "  ${0}",
      "}"
    ],
    "description": "While loop"
  },
  "Loop Times": {
    "prefix": "loop",
    "body": [
      "loop ${1:n} times {",
      "  ${0}",
      "}"
    ],
    "description": "Loop N times"
  },
  "Let": {
    "prefix": "let",
    "body": "let ${1:name} = ${0}",
    "description": "Variable declaration"
  },
  "Say": {
    "prefix": "say",
    "body": "say \"${0}\"",
    "description": "Print a value"
  },
  "Map": {
    "prefix": "map",
    "body": "map(${1:arr}, fn(${2:x}) { return ${0} })",
    "description": "Map over array"
  },
  "Filter": {
    "prefix": "filter",
    "body": "filter(${1:arr}, fn(${2:x}) { return ${0} })",
    "description": "Filter array"
  },
  "Reduce": {
    "prefix": "reduce",
    "body": "reduce(${1:arr}, fn(${2:acc}, ${3:x}) { return ${0} }, ${4:init})",
    "description": "Reduce array"
  }
}
